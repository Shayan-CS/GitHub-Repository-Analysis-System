# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=github_analysis
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/github_analysis

# GitHub token (optional, improves rate limits)
GITHUB_TOKEN=

# FastAPI
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Spring Boot
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/github_analysis
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
FASTAPI_BASE_URL=http://fastapi:8000

# ChromaDB
CHROMA_URL=http://chroma:8001
